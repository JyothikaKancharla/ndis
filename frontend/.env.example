# Frontend Configuration

# API Server URL
REACT_APP_API_URL=http://localhost:5000

# Timezone Configuration
# Supported timezones:
#   - Australia/Sydney (default) - Australian Eastern Time (AEDT/AEST)
#   - Asia/Kolkata - Indian Standard Time (IST)
#
# This timezone setting controls how dates and shift times are displayed
# and how shift status (Current/Pending/Previous) is calculated on the frontend
#REACT_APP_TIMEZONE=Australia/Sydney
 REACT_APP_TIMEZONE=Asia/Kolkata
