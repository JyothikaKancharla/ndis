# Backend Configuration

# Server Port
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb+srv://care_admin:YOUR_PASSWORD@cluster0.q9wggmu.mongodb.net/?appName=Cluster0

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key

# Timezone Configuration
# Supported timezones:
#   - Australia/Sydney (default) - Australian Eastern Time (AEDT/AEST)
#   - Asia/Kolkata - Indian Standard Time (IST)
#
# This timezone setting controls how dates and shift times are compared
# and how shift status is calculated on the backend
#TIMEZONE=Australia/Sydney
 TIMEZONE=Asia/Kolkata
